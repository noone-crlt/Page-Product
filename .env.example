VITE_API_BASE_URL=https://myapp-fmoh.onrender.com
VITE_PAYMENT_HUB_URL=https://myapp-fmoh.onrender.com/paymentHub

# Thông tin tài khoản nhận tiền đã liên kết với SePay.
# VITE_SEPAY_BANK_NAME dùng mã/tên ngân hàng mà SePay hỗ trợ, ví dụ MB hoặc MBBank.
VITE_SEPAY_BANK_ACCOUNT=YOUR_BANK_ACCOUNT
VITE_SEPAY_BANK_NAME=YOUR_BANK_CODE

# Nội dung thanh toán mặc định sẽ là DH{orderId}, ví dụ DH16.
# Giá trị này phải trùng với quy tắc đối chiếu trong webhook backend.
VITE_SEPAY_TRANSFER_PREFIX=DH
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_GEMINI_MODEL=gemini-3.5-flash

